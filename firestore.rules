rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is active
    function isActiveUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null || !("isActive" in userDoc.data) || userDoc.data.isActive != false;
    }

    // Check if user is authenticated and active
    function isAuthenticated() {
      return request.auth != null && isActiveUser();
    }

    // Check if user is admin or auditor
    function isElevated() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return isAuthenticated() && userDoc != null && (userDoc.data.role == "admin" || userDoc.data.role == "auditor");
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      // SECURITY AUDITOR FIX: Prevent users from updating their role, email or active status
      allow update: if isAuthenticated() && (
                      (request.auth.uid == userId && 
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'isActive', 'email']))
                      || isElevated()
                    );
      allow create, delete: if isElevated();
    }

    match /analyses/{analysisId} {
      allow read: if isElevated() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isElevated();
    }

    match /reports/{reportId} {
      allow read: if isElevated() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isElevated();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.userId == 'global' || isElevated());
      allow create: if isElevated();
      allow update: if isAuthenticated() && (
                      (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
                      || 
                      (resource.data.userId == 'global' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy']))
                      || isElevated()
                    );
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isElevated();
    }
    
    match /public_reports/{token} {
      allow read: if true;
      allow write: if isElevated();
    }
    
    match /global_config/{document=**} {
      allow read: if true;
      allow write: if isElevated();
    }
  }
}