rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is active
    function isActiveUser() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc == null || userDoc.data.isActive != false;
    }

    // Check if user is authenticated and active
    function isAuthenticated() {
      return request.auth != null && isActiveUser();
    }

    // Check if user is admin or auditor
    function isElevated() {
      return isAuthenticated() && (request.auth.token.role == "admin" || request.auth.token.role == "auditor");
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isElevated());
    }

    match /analyses/{analysisId} {
      // Elevated roles can read all. Regular users can only read their own.
      allow read: if isElevated() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid 
                    && request.resource.data.fileType in ["image", "video"];
      allow update, delete: if isElevated();
    }

    match /reports/{reportId} {
      allow read: if isElevated() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.fileType in ["image", "video"];
      allow update, delete: if isElevated();
    }
    
    match /public_reports/{token} {
      allow read: if true;
      allow write: if isElevated();
    }
    
    match /global_config/{document=**} {
      allow read: if true;
      allow write: if isElevated();
    }
  }
}